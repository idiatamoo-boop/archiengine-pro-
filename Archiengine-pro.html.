'use client';

import { useState } from 'react';
import { useRouter } from 'next/navigation';
import { loadStripe } from '@stripe/stripe-js';
import { STRIPE_PUBLISHABLE_KEY } from '@/lib/stripe';
import { Check, Sparkles } from 'lucide-react';

const stripePromise = loadStripe(STRIPE_PUBLISHABLE_KEY);

interface PricingCardProps {
  plan: any;
  session: any;
  popular?: boolean;
}

export function PricingCard({ plan, session, popular }: PricingCardProps) {
  const [isLoading, setIsLoading] = useState(false);
  const router = useRouter();

  const handleSubscribe = async () => {
    if (!session) {
      router.push('/auth/login/?callbackUrl=/pricing/');
      return;
    }

    if (plan.price === 0) {
      router.push('/dashboard/');
      return;
    }

    setIsLoading(true);
    try {
      const response = await fetch('/api/stripe/checkout/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ priceId: plan.priceId, planType: plan.id.toUpperCase() }),
      });
      const { url } = await response.json();
      window.location.href = url;
    } catch (error) {
      alert('Something went wrong. Please try again.');
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div className={`relative rounded-2xl p-8 ${popular ? 'bg-gradient-to-b from-blue-600 to-blue-800 border-2 border-blue-400' : 'bg-slate-800/50 border border-slate-700'}`}>
      {popular && (
        <div className="absolute -top-4 left-1/2 -translate-x-1/2">
          <span className="bg-gradient-to-r from-yellow-400 to-orange-500 text-slate-900 px-4 py-1 rounded-full text-sm font-bold flex items-center gap-1">
            <Sparkles className="h-4 w-4" /> Most Popular
          </span>
        </div>
      )}

      <h3 className="text-2xl font-bold mb-2 text-white">{plan.name}</h3>
      <p className={`mb-6 ${popular ? 'text-blue-100' : 'text-slate-400'}`}>{plan.description}</p>

      <div className="mb-6">
        <span className="text-4xl font-bold text-white">${plan.price}</span>
        {plan.price > 0 && <span className={popular ? 'text-blue-200' : 'text-slate-400'}>/month</span>}
      </div>

      <ul className="space-y-4 mb-8">
        {plan.features.map((feature: string) => (
          <li key={feature} className="flex items-start gap-3">
            <Check className={`h-5 w-5 mt-0.5 ${popular ? 'text-blue-200' : 'text-emerald-400'}`} />
            <span className={popular ? 'text-blue-100' : 'text-slate-300'}>{feature}</span>
          </li>
        ))}
      </ul>

      <button
        onClick={handleSubscribe}
        disabled={isLoading}
        className={`w-full py-3 rounded-xl font-semibold transition ${popular ? 'bg-white text-blue-600 hover:bg-blue-50' : 'bg-blue-600 text-white hover:bg-blue-700'} disabled:opacity-50`}
      >
        {isLoading ? 'Loading...' : plan.cta}
      </button>
    </div>
  );
}

