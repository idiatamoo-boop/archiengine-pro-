import OpenAI from 'openai';
import { prisma } from './prisma';
import { PlanType } from '@prisma/client';

const openai = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY,
});

const RATE_LIMITS = { FREE: 3, PRO: 1000, ENTERPRISE: 10000 };
const MODELS = { FREE: 'dall-e-2', PRO: 'dall-e-3', ENTERPRISE: 'dall-e-3' };
const SIZES = { FREE: '512x512', PRO: '1024x1024', ENTERPRISE: '1792x1024' };

interface GenerateParams {
  prompt: string;
  userId: string;
  plan: PlanType;
  projectId: string;
  style?: string;
  setting?: string;
  timeOfDay?: string;
}

export async function generateArchitecturalDesign({
  prompt, userId, plan, projectId, style = 'modern', setting = 'urban', timeOfDay = 'daylight'
}: GenerateParams) {
  
  if (plan === 'FREE') {
    const usageCount = await prisma.aIDesign.count({
      where: {
        project: { userId },
        createdAt: { gte: new Date(new Date().setDate(new Date().getDate() - 30)) },
      },
    });
    if (usageCount >= RATE_LIMITS.FREE) {
      throw new Error('Free tier limit reached. Upgrade to Pro for unlimited designs.');
    }
  }

  const enhancedPrompt = `Professional architectural visualization: ${prompt}. Style: ${style} architecture. Setting: ${setting} environment. Lighting: ${timeOfDay}. Photorealistic 3D render, high-quality materials, professional composition, 8K quality.`;

  const response = await openai.images.generate({
    model: MODELS[plan],
    prompt: enhancedPrompt,
    size: SIZES[plan] as any,
    n: 1,
  });

  const cost = plan === 'FREE' ? 0.016 : plan === 'PRO' ? 0.08 : 0.12;

  const design = await prisma.aIDesign.create({
    data: {
      projectId,
      prompt: enhancedPrompt,
      imageUrl: response.data[0].url,
      settings: { style, setting, timeOfDay, model: MODELS[plan] },
    },
  });

  await prisma.aIUsage.create({
    data: { userId, model: MODELS[plan], cost, prompt: prompt.substring(0, 500) },
  });

  return { id: design.id, url: response.data[0].url, prompt: enhancedPrompt };
}

