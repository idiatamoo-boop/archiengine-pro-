import { NextResponse } from 'next/server';
import { headers } from 'next/headers';
import { stripe } from '@/lib/stripe';
import { prisma } from '@/lib/prisma';
import Stripe from 'stripe';

const webhookSecret = process.env.STRIPE_WEBHOOK_SECRET!;

export async function POST(req: Request) {
  const payload = await req.text();
  const signature = headers().get('stripe-signature');

  if (!signature) {
    return new NextResponse('No signature', { status: 400 });
  }

  let event: Stripe.Event;

  try {
    event = stripe.webhooks.constructEvent(payload, signature, webhookSecret);
  } catch (err: any) {
    return new NextResponse(`Webhook Error: ${err.message}`, { status: 400 });
  }

  try {
    switch (event.type) {
      case 'checkout.session.completed': {
        const session = event.data.object as Stripe.Checkout.Session;
        const { userId, planType } = session.metadata as { userId: string; planType: string };
        
        const subscription = await stripe.subscriptions.retrieve(session.subscription as string);
        
        await prisma.subscription.upsert({
          where: { userId },
          create: {
            userId,
            status: 'ACTIVE',
            plan: planType as any,
            priceId: session.line_items?.data[0]?.price?.id,
            subscriptionId: session.subscription as string,
            currentPeriodStart: new Date(subscription.current_period_start * 1000),
            currentPeriodEnd: new Date(subscription.current_period_end * 1000),
          },
          update: {
            status: 'ACTIVE',
            plan: planType as any,
            priceId: session.line_items?.data[0]?.price?.id,
            subscriptionId: session.subscription as string,
            currentPeriodStart: new Date(subscription.current_period_start * 1000),
            currentPeriodEnd: new Date(subscription.current_period_end * 1000),
          },
        });

        await prisma.user.update({
          where: { id: userId },
          data: { role: planType === 'ENTERPRISE' ? 'PREMIUM' : 'USER' },
        });

        await prisma.payment.create({
          data: {
            userId,
            amount: session.amount_total ? session.amount_total / 100 : 0,
            currency: session.currency?.toUpperCase() || 'USD',
            status: 'COMPLETED',
            paymentIntentId: session.payment_intent as string,
            description: `Subscription to ${planType} plan`,
          },
        });
        break;
      }

      case 'customer.subscription.deleted': {
        const subscription = event.data.object as Stripe.Subscription;
        const userId = subscription.metadata.userId;

        await prisma.subscription.update({
          where: { userId },
          data: { status: 'CANCELED', plan: 'FREE' },
        });

        await prisma.user.update({
          where: { id: userId },
          data: { role: 'USER' },
        });
        break;
      }
    }

    return NextResponse.json({ received: true });
  } catch (error) {
    return new NextResponse('Webhook handling failed', { status: 500 });
  }
